TZ=America/Chicago
NODE_ENV=production

# where the API listens inside container
PORT=8002


# Postgres connectivity (your app should read these or DATABASE_URL—pick ONE style and stick to it)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=rag
POSTGRES_USER=rag
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# created by bootstrap script
DATABASE_URL=postgresql://rag:CHANGE_ME_STRONG_PASSWORD@postgres:5432/rag?sslmode=disable

EMBED_SECRET=CHANGE_ME
PORTFOLIO_LOCK_ENABLED=true
